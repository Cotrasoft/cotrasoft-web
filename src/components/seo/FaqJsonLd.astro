---
interface FaqItem {
	question: string;
	answer: string;
}

interface Props {
	items: FaqItem[];
}

const { items } = Astro.props;

const data = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: items.map((item) => ({
		'@type': 'Question',
		name: item.question,
		acceptedAnswer: {
			'@type': 'Answer',
			text: item.answer,
		},
	})),
};
---

{
	items.length > 0 && (
		<script
			type="application/ld+json"
			is:inline
			set:html={JSON.stringify(data)}
		/>
	)
}
