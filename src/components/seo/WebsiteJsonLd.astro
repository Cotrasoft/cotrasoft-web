---
import type { SupportedLang } from '../BaseHead.astro';

interface Props {
	lang?: SupportedLang;
}

const { lang = 'es' } = Astro.props;

const siteURL = Astro.site!;
const data = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: 'Cotrasoft',
	url: siteURL.href,
	inLanguage: lang,
	publisher: { '@id': new URL('#organization', siteURL).href },
};
---

<script
	type="application/ld+json"
	is:inline
	set:html={JSON.stringify(data)}
/>
