---
import Icon from './Icon.astro';
import type { IconName } from './icons';
import type { SupportedLang } from './BaseHead.astro';

interface BenefitItem {
	title: string;
	description: string;
}

interface BenefitsContent {
	heading: string;
	subheading: string;
	cta: string;
	items: BenefitItem[];
}

interface Props {
	content?: Partial<BenefitsContent>;
}

const { content = {} } = Astro.props;
const lang = (Astro.currentLocale ?? 'es') as SupportedLang;

const defaults: Record<SupportedLang, BenefitsContent> = {
	es: {
		heading: 'Beneficios para miembros',
		subheading:
			'Únete a nuestra cooperativa y disfruta de ventajas exclusivas diseñadas para impulsar tu carrera',
		cta: 'Descubre más beneficios',
		items: [
			{
				title: 'Comunidad colaborativa',
				description: 'Forma parte de una red de desarrolladores talentosos y apasionados',
			},
			{
				title: 'Crecimiento profesional',
				description: 'Oportunidades de desarrollo y aprendizaje continuo',
			},
			{
				title: 'Recursos de aprendizaje',
				description: 'Acceso a cursos, talleres y materiales educativos',
			},
			{
				title: 'Soporte mutuo',
				description: 'Mentorías y apoyo técnico de la comunidad',
			},
			{
				title: 'Proyectos globales',
				description: 'Participa en proyectos internacionales desafiantes',
			},
			{
				title: 'Beneficios cooperativos',
				description: 'Participación en ganancias y toma de decisiones',
			},
		],
	},
	en: {
		heading: 'Member benefits',
		subheading:
			'Join our cooperative and enjoy exclusive advantages designed to boost your career',
		cta: 'Discover more benefits',
		items: [
			{
				title: 'Collaborative community',
				description: 'Be part of a network of talented and passionate developers',
			},
			{
				title: 'Professional growth',
				description: 'Continuous development and learning opportunities',
			},
			{
				title: 'Learning resources',
				description: 'Access to courses, workshops, and educational materials',
			},
			{
				title: 'Mutual support',
				description: 'Mentorship and technical support from the community',
			},
			{
				title: 'Global projects',
				description: 'Participate in challenging international projects',
			},
			{
				title: 'Cooperative benefits',
				description: 'Profit sharing and decision-making participation',
			},
		],
	},
};

const t: BenefitsContent = { ...defaults[lang], ...content };

const benefitIcons: IconName[] = [
	'users',
	'trending-up',
	'book',
	'life-buoy',
	'globe',
	'heart',
];

const benefits = t.items.map((item, i) => ({
	icon: benefitIcons[i] ?? 'check',
	...item,
}));

const ctaHref = 'https://app.cotrasoft.co/registro';
---

<section
	id="beneficios"
	aria-labelledby="benefits-heading"
	class="section-padding bg-white dark:bg-gray-900"
>
	<div class="mx-auto max-w-7xl">
		<div class="reveal mb-16 text-center">
			<h2
				id="benefits-heading"
				class="mb-4 text-3xl sm:text-4xl font-bold gradient-text"
			>
				{t.heading}
			</h2>
			<p class="mx-auto max-w-3xl text-xl text-gray-600 dark:text-gray-300">
				{t.subheading}
			</p>
		</div>

		<div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
			{
				benefits.map((benefit, index) => (
					<article
						class="reveal rounded-xl bg-gray-50 p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl dark:bg-gray-800"
						style={`--reveal-delay: ${index * 100}ms`}
					>
						<div class="mb-4 flex items-center">
							<div class="flex size-12 items-center justify-center rounded-full bg-primary-100 text-primary-700">
								<Icon name={benefit.icon} class="size-6" />
							</div>
							<h3 class="ml-4 text-xl font-semibold dark:text-white">
								{benefit.title}
							</h3>
						</div>
						<p class="ml-16 text-gray-600 dark:text-gray-300">
							{benefit.description}
						</p>
					</article>
				))
			}
		</div>

		<div class="reveal mt-16 text-center">
			<a href={ctaHref} class="btn-primary inline-flex items-center space-x-2">
				<span>{t.cta}</span>
			</a>
		</div>
	</div>
</section>
